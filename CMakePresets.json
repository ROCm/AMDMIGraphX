{
    "version": 3,
    "configurePresets": [
        {
            "name": "WinBase",
            "cacheVariables": {
                "CMAKE_MAKE_PROGRAM": "$env{JOM_INSTALL_DIR}/jom.exe",
                "CMAKE_C_COMPILER": "$env{ROCM_DIR}/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "$env{ROCM_DIR}/bin/clang++.exe",
                "GPU_TARGETS": "$env{GPU_TARGETS}",
                "MIGRAPHX_USE_HIPRTC": "ON",
                "MIGRAPHX_DISABLE_LARGE_BUFFER_TESTS": "ON",
                "CMAKE_COMPILE_WARNING_AS_ERROR": "ON"
            },
            "generator": "NMake Makefiles JOM"
        },
        {
            "name": "WinMinSizeRel",
            "inherits": "WinBase",
            "displayName": "AMDMIGraphX MinSizeRel (Windows)",
            "description": "AMDMIGraphX MinSizeRel with NMake Makefiles JOM generator (Windows)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "CMAKE_PREFIX_PATH": "${sourceDir}/depend/MinSizeRel;C:\\opt\\rocMLIR\\MinSizeRel;C:/opt/rocm"
            },
            "binaryDir": "${sourceDir}/build/MinSizeRel"
        },
        {
            "name": "WinDebug",
            "inherits": "WinBase",
            "displayName": "AMDMIGraphX Debug (Windows)",
            "description": "AMDMIGraphX Debug with NMake Makefiles JOM generator (Windows)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "${sourceDir}/depend/Debug;C:\\opt\\rocMLIR\\Debug;C:/opt/rocm"
            },
            "binaryDir": "${sourceDir}/build/Debug"
        },
        {
            "name": "WinRelWithDebInfo",
            "inherits": "WinBase",
            "displayName": "AMDMIGraphX RelWithDebInfo (Windows)",
            "description": "AMDMIGraphX RelWithDebInfo with NMake Makefiles JOM generator (Windows)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_PREFIX_PATH": "${sourceDir}/depend/RelWithDebInfo;C:\\opt\\rocMLIR\\RelWithDebInfo;C:/opt/rocm"
            },
            "binaryDir": "${sourceDir}/build/RelWithDebInfo"
        },
        {
            "name": "WinRelease",
            "inherits": "WinBase",
            "displayName": "AMDMIGraphX Release (Windows)",
            "description": "AMDMIGraphX Release with NMake Makefiles JOM generator (Windows)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "${sourceDir}/depend/Release;C:\\opt\\rocMLIR\\Release;C:/opt/rocm"
            },
            "binaryDir": "${sourceDir}/build/Release"
        }
    ],
    "buildPresets": [
        {
            "name": "WinMinSizeRel",
            "configurePreset": "WinMinSizeRel"
        },
        {
            "name": "WinDebug",
            "configurePreset": "WinDebug"
        },
        {
            "name": "WinRelWithDebInfo",
            "configurePreset": "WinRelWithDebInfo"
        },
        {
            "name": "WinRelease",
            "configurePreset": "WinRelease"
        }
    ],
    "testPresets": [
        {
            "name": "WinMinSizeRel",
            "configurePreset": "WinMinSizeRel",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "WinDebug",
            "configurePreset": "WinDebug",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "WinRelWithDebInfo",
            "configurePreset": "WinRelWithDebInfo",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        },
        {
            "name": "WinRelease",
            "configurePreset": "WinRelease",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error",
                "stopOnFailure": true
            }
        }
    ]
}